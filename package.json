{
  "name": "nmos-simple-rds-studio",
  "version": "0.1.0",
  "description": "A desktop app for visualizing and troubleshooting AMWA IS-04 Registration & Discovery System",
  "main": "src/main.js",
  "author": "taqq505",
  "license": "Apache-2.0",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:icons": "node scripts/build-icons.js",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.nmos-simple.rds-studio",
    "productName": "NMOS Simple RDS Studio",
    "copyright": "Copyright © 2026 taqq505",
    "files": [
      "src/**/*",
      "bin/${os}/${arch}/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "bin/${os}/${arch}",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.icns"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "i18next": "^23.0.0"
  }
}
